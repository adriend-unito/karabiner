{
  "title": "Silakka58 Vial Layout",
  "rules": [
    {
      "description": "Silakka58: CapsLock = tap Escape / hold Left Control",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "caps_lock", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "left_control" }],
          "to_if_alone": [{ "key_code": "escape" }]
        }
      ]
    },
    {
      "description": "Silakka58: Z = tap Z / hold Left Option",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "z", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "left_option" }],
          "to_if_alone": [{ "key_code": "z" }]
        }
      ]
    },
    {
      "description": "Silakka58: Slash = tap / / hold Right Option",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "slash", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "right_option" }],
          "to_if_alone": [{ "key_code": "slash" }]
        }
      ]
    },
    {
      "description": "Silakka58: Right Command = Meh (Ctrl+Shift+Alt) on hold (optional, comment out if unwanted)",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "right_command", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "left_control", "modifiers": ["left_shift", "left_option"] }]
        }
      ]
    },
    {
      "description": "Silakka58: Space = tap Space / hold Layer 1",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "spacebar", "modifiers": { "optional": ["any"] } },
          "to": [{ "set_variable": { "name": "silakka_layer1", "value": 1 } }],
          "to_after_key_up": [{ "set_variable": { "name": "silakka_layer1", "value": 0 } }],
          "to_if_alone": [{ "key_code": "spacebar" }],
          "parameters": { "basic.to_if_alone_timeout_milliseconds": 175 }
        }
      ]
    },
    {
      "description": "Silakka58: Enter = tap Enter / hold Layer 2",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "return_or_enter", "modifiers": { "optional": ["any"] } },
          "to": [{ "set_variable": { "name": "silakka_layer2", "value": 1 } }],
          "to_after_key_up": [{ "set_variable": { "name": "silakka_layer2", "value": 0 } }],
          "to_if_alone": [{ "key_code": "return_or_enter" }],
          "parameters": { "basic.to_if_alone_timeout_milliseconds": 175 }
        }
      ]
    },
    {
      "description": "Silakka58 Layer 1 (Space held): F-keys, symbols, brackets",
      "manipulators": [
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "1", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "f1" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "2", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "f2" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "3", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "f3" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "4", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "f4" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "5", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "f5" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "6", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "f6" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "7", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "f7" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "8", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "f8" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "9", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "f9" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "0", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "f10" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "backslash", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "f11" }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "quote", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "f12" }] },

        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "q", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "1", "modifiers": ["left_shift"] }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "w", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "2", "modifiers": ["left_shift"] }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "e", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "3", "modifiers": ["left_shift"] }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "r", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "4", "modifiers": ["left_shift"] }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "t", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "5", "modifiers": ["left_shift"] }] },

        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "a", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "6", "modifiers": ["left_shift"] }] },
