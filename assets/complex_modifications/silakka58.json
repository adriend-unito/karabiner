        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "d", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "8", "modifiers": ["left_shift"] }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "f", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "9", "modifiers": ["left_shift"] }] },
        { "type": "basic", "conditions": [{ "type": "variable_if", "name": "silakka_layer1", "value": 1 }], "from": { "key_code": "g", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "0", "modifiers": ["left_shift"] }] },

